# Docker Compose Environment Variables
# Copy this file to .env.docker and modify as needed

# PostgreSQL Configuration
POSTGRES_USER=whiteboard
POSTGRES_PASSWORD=whiteboard123
POSTGRES_DB=whiteboard

# JWT (required by server; override in production)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend Configuration
# Set these to your production domain
VITE_API_BASE=http://localhost:3000
VITE_WS_URL=http://localhost:3000

# For production with a domain:
# VITE_API_BASE=https://api.yourdomain.com
# VITE_WS_URL=https://api.yourdomain.com
