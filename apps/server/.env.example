# PostgreSQL
DATABASE_URL=postgresql://whiteboard:whiteboardpassword@localhost:5432/whiteboard

# HTTP
PORT=4000

# Redis (use memory:// for local tests without Redis)
REDIS_URL=redis://localhost:6379

# JWT
