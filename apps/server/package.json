{
  "name": "@whiteboard/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "lint": "eslint .",
    "prisma:validate": "bunx --bun prisma validate",
    "prisma:format": "bunx --bun prisma format",
    "prisma:generate": "bunx --bun prisma generate",
    "prisma:migrate": "bunx --bun prisma migrate dev",
    "prisma:status": "bunx --bun prisma status",
    "prisma:deploy": "bunx --bun prisma deploy",
    "prisma:dbpush": "bunx --bun prisma db push"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@whiteboard/shared": "workspace:*",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "bun-types": "latest",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
