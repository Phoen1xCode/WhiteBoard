generator client {
    provider = "prisma-client"
    output   = "../prisma/generated"
}

datasource db {
    provider = "postgresql"
}

model Board {
    id        String   @id @default(cuid())
    title     String
    snapshot  Json // { elements: [...] }
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
