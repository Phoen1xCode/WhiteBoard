datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

model Board {
  id        String   @id @default(cuid())
  title     String
  snapshot  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
