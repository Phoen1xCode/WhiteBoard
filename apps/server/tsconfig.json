{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "paths": {
      "@whiteboard/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*"]
}
