{
  "name": "whiteboard",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev:web": "pnpm --filter @whiteboard/web dev",
    "dev:server": "pnpm --filter @whiteboard/server dev",
    "build:web": "pnpm --filter @whiteboard/web build",
    "lint": "pnpm -r lint",
    "prisma:generate": "pnpm --filter @whiteboard/server prisma:generate",
    "prisma:migrate": "pnpm --filter @whiteboard/server prisma:migrate"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
